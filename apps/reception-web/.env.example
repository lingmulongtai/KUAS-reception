# Firebase 設定
# Firebase Console → プロジェクト設定 → 全般 → マイアプリ から取得
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# Cloud Functions の URL
# 本番環境: https://asia-northeast1-<project-id>.cloudfunctions.net/api
# 開発環境 (エミュレータ): http://localhost:5001/<project-id>/us-central1/api
VITE_API_BASE_URL=https://asia-northeast1-your-project-id.cloudfunctions.net/api
